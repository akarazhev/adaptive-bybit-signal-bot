SYMBOLS=BTCUSDT,ETHUSDT
APP_ENV=local
DATABASE_URL=sqlite:////data/bot.db
DB_WAIT_TIMEOUT_SECONDS=60
DB_WAIT_INTERVAL_SECONDS=2
LOG_LEVEL=INFO

BYBIT_BASE_URL=https://api.bybit.com
BYBIT_PUBLIC_WS_SPOT_URL=wss://stream.bybit.com/v5/public/spot
BYBIT_RECV_WINDOW=5000

# Optional read-only Bybit credentials.
# BYBIT_API_KEY=
# BYBIT_API_SECRET=
BYBIT_ALLOW_READ_WRITE_KEY=false

SERVICE_HEARTBEAT_SECONDS=15
SERVICE_HEARTBEAT_STALE_SECONDS=120
STRATEGY_LOCK_ENABLED=true
STRATEGY_LOCK_TTL_SECONDS=60
STRATEGY_WRITER_SERVICE=any

POLL_INTERVAL_SECONDS=10
KLINE_INTERVAL=1
KLINE_LIMIT=240
ORDERBOOK_LIMIT=50
RECENT_TRADES_LIMIT=60

WS_ORDERBOOK_DEPTH=50
WS_EVALUATION_INTERVAL_SECONDS=10
WS_CANDLE_REFRESH_SECONDS=30
WS_TRADE_LOOKBACK_SECONDS=120
WS_MAX_TRADES_PER_SYMBOL=2000

ORDER_QUOTE_USDT=50
MAX_POSITION_QUOTE_USDT=250
SPOT_MAKER_FEE_BPS=10
SPOT_TAKER_FEE_BPS=10
MIN_NET_PROFIT_BPS=12
SAFETY_BUFFER_BPS=5
MAX_SPREAD_BPS=8
MAX_ATR_PCT=1.4
SHOCK_ATR_PCT=1.2
MAX_UNREALIZED_LOSS_BPS=80
MAX_POSITION_AGE_SECONDS=7200
ORDER_TTL_SECONDS=120
REPRICE_THRESHOLD_BPS=4
MIN_EXPECTED_EDGE_BPS=30

FNG_ENABLED=false
FNG_BASE_URL=https://api.alternative.me
FNG_REFRESH_SECONDS=21600
FNG_STALE_AFTER_HOURS=36
FNG_HISTORY_LIMIT=30
FNG_BTC_WEIGHT=1.0
FNG_ETH_WEIGHT=0.6
FNG_ALT_WEIGHT=0.5
FNG_EXTREME_FEAR_SIZE_MULTIPLIER=0.5
FNG_FEAR_SIZE_MULTIPLIER=0.8
FNG_GREED_SIZE_MULTIPLIER=0.6
FNG_EXTREME_GREED_SIZE_MULTIPLIER=0.4
FNG_EXTREME_FEAR_EXTRA_EDGE_BPS=5
FNG_GREED_EXTRA_EDGE_BPS=8
FNG_EXTREME_GREED_EXTRA_EDGE_BPS=15
FNG_EXTREME_FEAR_BUY_DISTANCE_MULTIPLIER=1.25
FNG_FEAR_BUY_DISTANCE_MULTIPLIER=1.10
FNG_GREED_BUY_DISTANCE_MULTIPLIER=1.25
FNG_EXTREME_GREED_BUY_DISTANCE_MULTIPLIER=1.50
FNG_GREED_TTL_MULTIPLIER=0.75
FNG_EXTREME_GREED_TTL_MULTIPLIER=0.50
FNG_GREED_SELL_TARGET_MULTIPLIER=0.92
FNG_EXTREME_GREED_SELL_TARGET_MULTIPLIER=0.85

INSTRUMENT_REFRESH_SECONDS=43200

PAPER_TRADING_ENABLED=false
PAPER_FILL_MODE=trade_through
PAPER_MIN_FILL_RATIO=1.0
PAPER_MAX_TRADE_AGE_SECONDS=300
PAPER_LOOP_INTERVAL_SECONDS=10

BACKTEST_STARTING_QUOTE=10000
BACKTEST_WARMUP_CANDLES=240
BACKTEST_SYNTHETIC_SPREAD_BPS=2
BACKTEST_FORCE_CLOSE=true

MARKET_RECORDING_DIR=/data/market-recordings
MARKET_RECORDING_ORDERBOOK_DEPTH=50
MARKET_RECORDING_COMPRESS=true
MARKET_RECORDING_FLUSH_EVERY_EVENTS=1000

REPLAY_INTERVAL_SECONDS=60
REPLAY_EVALUATION_INTERVAL_SECONDS=10
REPLAY_WARMUP_CANDLES=60
REPLAY_TRADE_LOOKBACK_SECONDS=120
REPLAY_FILL_MODEL=trade_through
REPLAY_FORCE_CLOSE=true
